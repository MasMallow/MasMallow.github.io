{
  "rules": {
    "app_data": {
      ".read": true,
      ".write": "auth != null && root.child('organizers').child(auth.uid).val() === true",
      ".validate": "newData.hasChildren(['rev', 'savedAt'])",
      "rev": {
        ".validate": "newData.isNumber() && newData.val() >= 0 && (!data.exists() ? newData.val() <= 1 : newData.val() === data.val() + 1)"
      },
      "savedAt": {
        ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= now + 10000 && (!data.exists() || newData.val() >= data.val())"
      },
      "data": {
        "$child": {
          ".validate": "$child === 'builds' || $child === 'comps'"
        }
      },
      "$other": {
        ".validate": false
      }
    },
    "organizers": {
      ".read": false,
      ".write": false,
      "$uid": {
        ".read": "auth != null && auth.uid === $uid"
      }
    },
    "signups": {
      ".read": true,
      "$compId": {
        ".write": "auth != null && root.child('organizers').child(auth.uid).val() === true",
        "$slotIdx": {
          ".write": true,
          "player": {
            ".validate": "newData.val() === null || (newData.isString() && newData.val().length <= 60)"
          },
          "note": {
            ".validate": "newData.val() === null || (newData.isString() && newData.val().length <= 200)"
          },
          "$other": {
            ".validate": false
          }
        }
      }
    }
  }
}
